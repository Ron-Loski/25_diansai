#**************************************************************
# Time Information
#**************************************************************

set_time_format -unit ns -decimal_places 3



#**************************************************************
# Create Clock
#**************************************************************

create_clock -name {clk} -period 20.000 -waveform { 0.000 10.000 } [get_ports {clk}]


#**************************************************************
# Create Generated Clock
#**************************************************************

create_generated_clock -name {U0_pll165m_inst|altpll_component|auto_generated|pll1|clk[1]} -source [get_pins {U0_pll165m_inst|altpll_component|auto_generated|pll1|inclk[0]}] -duty_cycle 50.000 -multiply_by 33 -divide_by 10 -master_clock {clk} [get_pins {U0_pll165m_inst|altpll_component|auto_generated|pll1|clk[1]}] 


