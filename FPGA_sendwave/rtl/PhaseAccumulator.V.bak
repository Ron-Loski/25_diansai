/*
输入信号：
CLK,
RSTn,
PhaseStep: 相位步进字
PhaseStart: 起始相位

输出信号：
MemAddr：存储器地址，
*/

module PhaseAccumulator(
   CLK, 
	 RSTn,
	 
	 PhaseStep,
	 MemAddr,
);

`define PhaseAcc_BITS_NUM	 32
`define Mem_BITS_NUM	 14

 input CLK;
 input RSTn;
 input[`PhaseAcc_BITS_NUM-1:0] PhaseStep;
 output [`Mem_BITS_NUM-1:0]MemAddr;
 
reg[`PhaseAcc_BITS_NUM-1:0] PhaseSum;
always @ ( posedge CLK or negedge RSTn)
if( !RSTn ) begin
	PhaseSum <= 32'd0;
end
else
begin
	PhaseSum <= PhaseSum + PhaseStep;
end

assign MemAddr = {PhaseSum[`PhaseAcc_BITS_NUM-1:`PhaseAcc_BITS_NUM-`Mem_BITS_NUM]};//取相位累加器高Mem_BITS_NUM位作为ROM寻址地址

endmodule
